# FastAPI backend blockchain integration settings
BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545
BLOCKCHAIN_CHAIN_ID=31337
BLOCKCHAIN_POA_ENABLED=false
CONTRACT_ADDRESS=0xYOUR_DEPLOYED_CONTRACT_ADDRESS
DEFAULT_SIGNER_PRIVATE_KEY=YOUR_MANAGER_PRIVATE_KEY_WITHOUT_0x
# Optional custom ABI location. If unset, built-in ABI file is used.
CONTRACT_ABI_PATH=

# Local IPFS API endpoint
IPFS_API_URL=http://127.0.0.1:5001
